# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =============================================================================
# SUPABASE (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# APP CONFIGURATION
# =============================================================================
APP_ENV=dev                      # dev | uat | production
NODE_ENV=development             # development | production
PORT=3000

# =============================================================================
# AEPS CONFIGURATION (Chagans API)
# =============================================================================
# Set to 'true' for development/testing, 'false' for production
AEPS_USE_MOCK=true

# Chagans AEPS API credentials (get from vendor)
CHAGHANS_AEPS_CLIENT_ID=your_client_id_here
CHAGHANS_AEPS_CONSUMER_SECRET=your_consumer_secret_here
CHAGHANS_AEPS_AUTH_TOKEN=your_jwt_token_here
CHAGHANS_AEPS_BASE_URL=https://chagans.com/aeps

# Optional: Custom mock base URL (defaults to localhost:3000)
# AEPS_MOCK_BASE_URL=http://localhost:3000/api/aeps

# =============================================================================
# BBPS CONFIGURATION (Bill Payments)
# =============================================================================
USE_BBPS_MOCK=false              # true for testing

# BBPS API credentials
BBPS_API_BASE_URL=
BBPS_PARTNER_ID=your_partner_id
BBPS_CONSUMER_KEY=your_consumer_key
BBPS_CONSUMER_SECRET=your_consumer_secret
BBPS_AUTH_TOKEN=your_bearer_token

# =============================================================================
# RAZORPAY (Payment Gateway)
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# EZETAP POS (Razorpay Terminal)
# =============================================================================
EZETAP_API_BASE_URL=https://www.ezetap.com
EZETAP_MERCHANT_CREDENTIALS_JSON={"merchant_name":{"username":"xxx","appKey":"xxx"}}

# =============================================================================
# SMTP (Email)
# =============================================================================
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yourdomain.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=info@yourdomain.com

# =============================================================================
# SETTLEMENT & CRON
# =============================================================================
SETTLEMENT_CRON_API_KEY=your_secure_cron_api_key
CRON_SECRET=your_cron_secret

# =============================================================================
# SUBSCRIPTION REVENUE TRACKING
# =============================================================================
SUBSCRIPTION_REVENUE_USER_ID=ADMIN_SUB_REVENUE
SUBSCRIPTION_REVENUE_USER_ROLE=master_distributor

# =============================================================================
# FRONTEND URLs
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# For EC2/Production:
# NEXT_PUBLIC_APP_URL=https://www.yourdomain.com
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# =============================================================================
# NEXTAUTH (if using NextAuth.js)
# =============================================================================
# NEXTAUTH_SECRET=your_nextauth_secret
# NEXTAUTH_URL=http://localhost:3000

AEPS_COMMISSION_ENABLED=true   # Enable commission distribution (master on/off, default: true)
# AEPS_SCHEME_ENABLED is deprecated — scheme engine is now the default with legacy fallback
AEPS_USE_MOCK=true             # Keep mock mode for staging

# =============================================================================
# EKYC HUB (KYC Verification API - connect.ekychub.in)
# =============================================================================
EKYCHUB_USERNAME=your_ekychub_username
EKYCHUB_TOKEN=your_ekychub_token
EKYCHUB_BASE_URL=https://connect.ekychub.in/v3
EKYCHUB_USE_MOCK=true          # true for dev/testing, false for production
EKYCHUB_TIMEOUT=30000          # API timeout in ms

# =============================================================================
# SHADVAL PAY (Payout API - partners.shadvalpay.co.in)
# =============================================================================
SHADVAL_PAY_KEY=your_shadval_key_here
SHADVAL_PAY_BASE_URL=https://partners.shadvalpay.co.in/api
SHADVAL_PAY_ENV=uat            # uat | production (controls endpoint prefixes)
SHADVAL_PAY_MOCK=false         # true for dev/testing without real API calls
SHADVAL_PAY_TIMEOUT=120000     # API timeout in ms

# =============================================================================
# PINELAB PineOne (POS Transaction Sync)
# =============================================================================
# JSON config for each merchant: { "slug": { merchantName, clientId, clientSecret, env } }
# Example:
# PINELAB_MERCHANTS_CONFIG={"avika":{"merchantName":"Avika Departmental Private Limited","clientId":"YOUR_CLIENT_ID","clientSecret":"YOUR_CLIENT_SECRET","env":"test"}}
PINELAB_MERCHANTS_CONFIG=
PINELAB_SYNC_INTERVAL_SECONDS=10     # Sync interval in seconds (default: 600 = 10 min)
