# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
*.lcov

# next.js
/.next/
/out/
.next
out

# production
/build
dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# local env files
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Logs
logs
*.log

# Temporary files
*.tmp
*.temp
.cache/

# PM2 and deployment configs (may contain sensitive info)
ecosystem.config.js
ec2.config.js
# Allow important config files (next.config.js, postcss.config.js, tailwind.config.ts)
!next.config.js
!postcss.config.js
!tailwind.config.ts

# Deployment scripts and server configs
*.sh
nginx-config*.conf
nginx-config*.txt

# Documentation files (deployment-specific, not needed in repo)
# Ignore ALL .md files except README.md
*.md
!README.md
# Legal agreement documents are runtime-served and MUST be tracked/deployed
!legal/**/*.md

# SQL files - Keep migration files but exclude temporary fix files
fix-add-ledger-entry-amount.sql
supabase-bbps2-pay2new-migration.sql

# Test files
src/test/
*.test.js
*.test.ts
*.test.ts

# Postman collections and API JSON (may contain credentials, tokens, or PII)
/API_Json/
/postman/
*postman*.json
*Postman*.json
SparkUpTech-Payout-API.postman_collection.json
