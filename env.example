# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# BBPS API Configuration
BBPS_API_BASE_URL=
BBPS_PARTNER_ID=your_bbps_partner_id
BBPS_CONSUMER_KEY=your_bbps_consumer_key
BBPS_CONSUMER_SECRET=your_bbps_consumer_secret
USE_BBPS_MOCK=false

# Payout API Configuration
PAYOUT_API_BASE_URL=
USE_PAYOUT_MOCK=false
PAYOUT_CHARGE_IMPS=5
PAYOUT_CHARGE_NEFT=3
PAYOUT_MIN_AMOUNT=100
PAYOUT_MAX_AMOUNT=200000

# BBPS Backend URL (Optional - EC2)
NEXT_PUBLIC_BBPS_BACKEND_URL=

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# MDR Settlement Cron Job (Generate a secure random string - 32+ characters)
# Use this key in EC2 cron script and in .env.local
SETTLEMENT_CRON_API_KEY=586b5d759bf449ac901bba3725183821c5d4f00dbdc94d17b635844755e29d95

# Admin Wallet (for company earnings in MDR scheme)
ADMIN_USER_ID=admin_user_id
ADMIN_USER_ROLE=master_distributor
# OR use existing master distributor
# MASTER_DISTRIBUTOR_ID=master_distributor_id

# Email Configuration (SMTP)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@samedaysolution.in
SMTP_PASSWORD=your_email_password
SMTP_FROM=info@samedaysolution.in

# Pay2New Credit Card Bill Payment
PAY2NEW_BASE_URL=https://pay2new.in
PAY2NEW_SECRET=your_pay2new_secret_key
PAY2NEW_OUTLET_ID=10820
PAY2NEW_TIMEOUT=90000
PAY2NEW_SERVER_IP=15.207.31.125
PAY2NEW_AGENT_MOBILE=
PAY2NEW_AGENT_PINCODE=414002
PAY2NEW_LATITUDE=19.1258
PAY2NEW_LONGITUDE=74.7453
USE_PAY2NEW_MOCK=false

# Application URL
NEXT_PUBLIC_APP_URL=https://samedaysolution.in

# Node Environment
NODE_ENV=development

