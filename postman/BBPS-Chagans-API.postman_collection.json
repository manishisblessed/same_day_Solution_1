{
  "info": {
    "_postman_id": "a1b2c3d4-bbps-chagans-0001",
    "name": "BBPS Utility Bill Payment — Chagans Technologies",
    "description": "Smoke / integration tests for Chagans BBPS.\n\n**Auth:** Paste `clientId`, `clientSecret`, and `bearerToken` from `.env.local` into collection Variables after import (do not commit secrets).\n\n**Default scenario:** SBI Card (C15 / SBIC00000NATDN) — last 4 digits + registered mobile. Run 3 → 4 → 5a or 5b. Step 3 saves enquiryId and syncs fetch param names; step 4 sends all parameters from `fetchParametersJson`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://chagans.com" },
    {
      "key": "clientId",
      "value": "YOUR_CLIENT_ID",
      "description": "From CHAGHANS_BBPS_CLIENT_ID in .env.local"
    },
    {
      "key": "clientSecret",
      "value": "YOUR_CLIENT_SECRET_UUID",
      "description": "From CHAGHANS_BBPS_CONSUMER_SECRET in .env.local"
    },
    {
      "key": "bearerToken",
      "value": "YOUR_BEARER_TOKEN",
      "description": "Raw token only (no Bearer prefix). From CHAGHANS_BBPS_AUTH_TOKEN in .env.local"
    },
    {
      "key": "merchantId",
      "value": "YOUR_MERCHANT_ID",
      "description": "From Chagans KYC / CHAGHANS_BBPS_MERCHANT_ID — required before pay"
    },
    { "key": "categoryKey", "value": "C15", "description": "Credit Card" },
    { "key": "billerId", "value": "SBIC00000NATDN", "description": "SBI Card" },
    { "key": "enquiryId", "value": "", "description": "Filled by step 3 (30 min TTL)" },
    { "key": "externalRef", "value": "CLIENTTXN001", "description": "Use a unique value per payment" },
    {
      "key": "billAmount",
      "value": "450",
      "description": "Overwritten from fetchBill response when step 4 succeeds"
    },
    { "key": "customerName", "value": "Test Customer" },
    { "key": "customerMobile", "value": "9971969046" },
    { "key": "customerEmail", "value": "customer@example.com" },
    { "key": "customerPan", "value": "" },
    { "key": "upiId", "value": "customer@upi" },
    {
      "key": "fetchParametersJson",
      "value": "{\"Last 4 digit of primary credit card number\":\"1290\",\"Mobile Number\":\"9971969046\"}",
      "description": "Multi-field fetch params. Step 3 refreshes keys from API, keeps prefilled values."
    },
    { "key": "fetchParamName", "value": "Last 4 digit of primary credit card number" },
    { "key": "fetchParamValue", "value": "1290" },
    { "key": "fetchParam2Name", "value": "Mobile Number" },
    { "key": "fetchParam2Value", "value": "9971969046" },
    { "key": "fetchParamMinLength", "value": "4" },
    { "key": "fetchParamMaxLength", "value": "4" },
    { "key": "fetchParamDataType", "value": "NUMERIC" },
    { "key": "createMerchantPath", "value": "bbps/createMerchant" }
  ],
  "item": [
    {
      "name": "0. Get Wallet Balance",
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"merchantId\": \"{{merchantId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/getWalletBalance",
        "description": "Merchant BBPS wallet balance (admin dashboard). Requires whitelisted IP. If you get 'Cannot POST /bbps/getWalletBalance', ask Chagans support for the correct wallet balance endpoint and set BBPS_CHAGANS_WALLET_PATH on EC2."
      },
      "response": []
    },
    {
      "name": "1. Get All Categories",
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/getCategory",
        "description": "Returns supported BBPS utility categories."
      },
      "response": []
    },
    {
      "name": "2. Get Billers by Category",
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"categoryKey\": \"{{categoryKey}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/getBiller",
        "description": "Default categoryKey C15 (Credit Card). Copy billerId from response if testing another biller."
      },
      "response": []
    },
    {
      "name": "3. Get Biller Input Fields",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "  const j = pm.response.json();",
              "  const eid = j.enquiryId || (j.data && j.data.enquiryId);",
              "  if (eid) {",
              "    pm.collectionVariables.set('enquiryId', eid);",
              "    console.log('Saved enquiryId:', eid);",
              "  } else {",
              "    console.warn('No enquiryId in response; check success and billerId.');",
              "  }",
              "  const rf = j.data && j.data.requiredFields;",
              "  if (Array.isArray(rf) && rf.length) {",
              "    let existing = {};",
              "    try { existing = JSON.parse(pm.collectionVariables.get('fetchParametersJson') || '{}'); } catch {}",
              "    const params = {};",
              "    rf.forEach((f, i) => {",
              "      const name = f.paramName;",
              "      const legacyVal = i === 0",
              "        ? pm.collectionVariables.get('fetchParamValue')",
              "        : pm.collectionVariables.get('fetchParam2Value');",
              "      params[name] = existing[name] || legacyVal || '';",
              "      if (i === 0) {",
              "        pm.collectionVariables.set('fetchParamName', name);",
              "        if (f.maxLength != null && String(f.maxLength) !== '') pm.collectionVariables.set('fetchParamMaxLength', String(f.maxLength));",
              "        if (f.minLength != null && String(f.minLength) !== '') pm.collectionVariables.set('fetchParamMinLength', String(f.minLength));",
              "        if (f.dataType) pm.collectionVariables.set('fetchParamDataType', String(f.dataType));",
              "      }",
              "      if (i === 1) pm.collectionVariables.set('fetchParam2Name', name);",
              "    });",
              "    pm.collectionVariables.set('fetchParametersJson', JSON.stringify(params));",
              "    console.log('Fetch parameters:', params);",
              "  }",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"billerId\": \"{{billerId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/getBillerField",
        "description": "Must succeed before fetch/pay. Saves enquiryId (30 min TTL) and syncs all requiredFields into fetchParametersJson."
      },
      "response": []
    },
    {
      "name": "4. Fetch Bill",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const eid = pm.collectionVariables.get('enquiryId');",
              "if (!eid || String(eid).trim() === '') {",
              "  throw new Error('enquiryId is empty. Run request 3 (Get Biller Input Fields) successfully first.');",
              "}",
              "const billerId = pm.collectionVariables.get('billerId');",
              "let parameters = {};",
              "const jsonStr = pm.collectionVariables.get('fetchParametersJson');",
              "if (jsonStr && String(jsonStr).trim()) {",
              "  try { parameters = JSON.parse(jsonStr); } catch (e) {",
              "    throw new Error('fetchParametersJson is invalid JSON');",
              "  }",
              "} else {",
              "  const name = pm.collectionVariables.get('fetchParamName');",
              "  const val = String(pm.collectionVariables.get('fetchParamValue') ?? '').trim();",
              "  if (name && val) parameters[name] = val;",
              "  const name2 = pm.collectionVariables.get('fetchParam2Name');",
              "  const val2 = String(pm.collectionVariables.get('fetchParam2Value') ?? '').trim();",
              "  if (name2 && val2) parameters[name2] = val2;",
              "}",
              "const keys = Object.keys(parameters);",
              "if (!keys.length) throw new Error('No fetch parameters set.');",
              "for (const [name, val] of Object.entries(parameters)) {",
              "  const v = String(val ?? '').trim();",
              "  if (!v) throw new Error('Empty value for parameter: ' + name);",
              "  if (/mobile/i.test(name) && !/^[6-9]\\d{9}$/.test(v)) {",
              "    throw new Error('Mobile Number must be 10 digits starting with 6-9');",
              "  }",
              "  if (!/mobile/i.test(name) && !/^\\d+$/.test(v)) {",
              "    throw new Error(name + ' must be digits only (NUMERIC)');",
              "  }",
              "  parameters[name] = v;",
              "}",
              "pm.request.body.raw = JSON.stringify({ billerId, enquiryId: eid, parameters });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "  const j = pm.response.json();",
              "  const amt = j.data && j.data.billerResponse && j.data.billerResponse.billAmount;",
              "  if (amt != null && String(amt) !== '') {",
              "    pm.collectionVariables.set('billAmount', String(amt));",
              "    console.log('Saved billAmount:', amt);",
              "  }",
              "  const mode = j.data && j.data.paymentMode;",
              "  if (mode) console.log('paymentMode:', mode, '→ use 5a for UPI, 5b for Cash');",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/fetchBill",
        "description": "Pre-request builds body from fetchParametersJson. Default SBI Card: last 4 = 1290, mobile = 9971969046. Always run step 3 first."
      },
      "response": []
    },
    {
      "name": "5a. Pay Bill (UPI — paymentMode UPI)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const eid = pm.collectionVariables.get('enquiryId');",
              "if (!eid || String(eid).trim() === '') {",
              "  throw new Error('enquiryId is empty. Run step 3 then 4 before pay.');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"billerId\": \"{{billerId}}\",\n  \"enquiryId\": \"{{enquiryId}}\",\n  \"amount\": \"{{billAmount}}\",\n  \"externalRef\": \"{{externalRef}}\",\n  \"merchantId\": \"{{merchantId}}\",\n  \"customerPan\": \"{{customerPan}}\",\n  \"customerName\": \"{{customerName}}\",\n  \"customerMobile\": \"{{customerMobile}}\",\n  \"customerEmail\": \"{{customerEmail}}\",\n  \"upiId\": \"{{upiId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/payBill",
        "description": "Only when fetchBill returned paymentMode UPI. customerMobile: 10-digit Indian number. Use a valid VPA in upiId."
      },
      "response": []
    },
    {
      "name": "5b. Pay Bill (Cash — paymentMode Cash)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const eid = pm.collectionVariables.get('enquiryId');",
              "if (!eid || String(eid).trim() === '') {",
              "  throw new Error('enquiryId is empty. Run step 3 then 4 before pay.');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"billerId\": \"{{billerId}}\",\n  \"enquiryId\": \"{{enquiryId}}\",\n  \"amount\": \"{{billAmount}}\",\n  \"externalRef\": \"{{externalRef}}_CASH\",\n  \"merchantId\": \"{{merchantId}}\",\n  \"customerPan\": \"{{customerPan}}\",\n  \"customerName\": \"{{customerName}}\",\n  \"customerMobile\": \"{{customerMobile}}\",\n  \"customerEmail\": \"{{customerEmail}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/bbps/payBill",
        "description": "Omit upiId when paymentMode is Cash. Same customer* fields as UPI flow."
      },
      "response": []
    },
    {
      "name": "6. Create Merchant (KYC)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "client-id", "value": "{{clientId}}" },
          { "key": "client-secret", "value": "{{clientSecret}}" },
          { "key": "authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "apiType", "value": "bbps" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"9876543210\",\n  \"name\": \"Test Merchant\",\n  \"gender\": \"M\",\n  \"pan\": \"ABCDE1234F\",\n  \"email\": \"merchant@example.com\",\n  \"address\": {\n    \"full\": \"123 Main Street\",\n    \"city\": \"Mumbai\",\n    \"pincode\": \"400001\"\n  },\n  \"aadhaar\": \"123456789012\",\n  \"dateOfBirth\": \"1990-01-15\",\n  \"latitude\": \"19.0760\",\n  \"longitude\": \"72.8777\",\n  \"bankAccountNo\": \"1234567890\",\n  \"bankIfsc\": \"SBIN0001234\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/{{createMerchantPath}}",
        "description": "PDF path was /createMerchant; host returned Cannot POST. Default URL uses createMerchantPath=bbps/createMerchant. If 404, edit collection variable to api/createMerchant or the path vendor provides. Body must be real KYC where required."
      },
      "response": []
    }
  ]
}
