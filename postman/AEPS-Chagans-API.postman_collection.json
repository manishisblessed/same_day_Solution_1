  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const raw = (pm.environment.get('CHAGHANS_AEPS_AUTH_TOKEN') || pm.collectionVariables.get('CHAGHANS_AEPS_AUTH_TOKEN') || '').trim();",
          "if (raw) {",
          "  const v = /^Bearer\\s+/i.test(raw) ? raw : ('Bearer ' + raw);",
          "  pm.request.headers.upsert({ key: 'authorization', value: v });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "2. Merchant Management",
      "item": [
        {
          "name": "2.1 Create Merchant",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('merchantEmail', 'aeps.kyc.' + ts + '@gmail.com');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response time OK', function () { pm.expect(pm.response.responseTime).to.be.below(30000); });",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const mid = j.data && j.data.merchantId;",
                  "  if (mid && /^[a-f0-9]{24}$/i.test(mid)) {",
                  "    pm.collectionVariables.set('merchantId', mid);",
                  "  }",
                  "  pm.test('Has JSON body', function () { pm.expect(j).to.be.an('object'); });",
                  "} catch (e) { pm.test('Parse JSON', function () { pm.expect.fail('Body is not JSON'); }); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "client-id", "value": "{{CHAGHANS_AEPS_CLIENT_ID}}" },
              { "key": "client-secret", "value": "{{CHAGHANS_AEPS_CONSUMER_SECRET}}" },
              { "key": "authorization", "value": "Bearer {{CHAGHANS_AEPS_AUTH_TOKEN}}" },
              { "key": "apiType", "value": "aeps" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"{{merchantMobile}}\",\n  \"name\": \"{{merchantName}}\",\n  \"gender\": \"{{merchantGender}}\",\n  \"pan\": \"{{merchantPan}}\",\n  \"email\": \"{{merchantEmail}}\",\n  \"address\": {\n    \"full\": \"123 Main Street, Andheri East\",\n    \"city\": \"Mumbai\",\n    \"pincode\": \"400001\"\n  },\n  \"aadhaar\": \"{{merchantAadhaar}}\",\n  \"dateOfBirth\": \"{{merchantDateOfBirth}}\",\n  \"latitude\": \"19.0760\",\n  \"longitude\": \"72.8777\",\n  \"bankAccountNo\": \"{{bankAccountNo}}\",\n  \"bankIfsc\": \"{{bankIfsc}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/aeps/createMerchant",
            "description": "JIO matches **name** (and often **DOB**) to **PAN** records. Set `merchantName` to the exact name on the PAN for `merchantPan`; set `merchantDateOfBirth` if needed. Pre-request sets unique email only. On success, saves `merchantId` when 24-char hex."
          },
          "response": []
        },
        {
          "name": "2.2 Merchant List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response time OK', function () { pm.expect(pm.response.responseTime).to.be.below(30000); });",
                  "try {",
                  "  const j = pm.response.json();",
                  "  pm.test('Has JSON body', function () { pm.expect(j).to.be.an('object'); });",
                  "} catch (e) { pm.test('Parse JSON', function () { pm.expect.fail('Body is not JSON'); }); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "client-id", "value": "{{CHAGHANS_AEPS_CLIENT_ID}}" },
              { "key": "client-secret", "value": "{{CHAGHANS_AEPS_CONSUMER_SECRET}}" },
              { "key": "authorization", "value": "Bearer {{CHAGHANS_AEPS_AUTH_TOKEN}}" },
              { "key": "apiType", "value": "aeps" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/aeps/merchantList?page=1&limit=10",
            "description": "`data: []` is expected until merchants exist for this partner."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. AEPS Authentication",
      "item": [
        {
          "name": "3.1 Check AEPS Login Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response time OK', function () { pm.expect(pm.response.responseTime).to.be.below(30000); });",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const d = j.data || {};",
                  "  if (d.wadh) pm.collectionVariables.set('aepsWadh', d.wadh);",
                  "  if (d.route) pm.collectionVariables.set('aepsRoute', d.route);",
                  "  pm.test('Has JSON body', function () { pm.expect(j).to.be.an('object'); });",
                  "} catch (e) { pm.test('Parse JSON', function () { pm.expect.fail('Body is not JSON'); }); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "client-id", "value": "{{CHAGHANS_AEPS_CLIENT_ID}}" },
              { "key": "client-secret", "value": "{{CHAGHANS_AEPS_CONSUMER_SECRET}}" },
              { "key": "authorization", "value": "Bearer {{CHAGHANS_AEPS_AUTH_TOKEN}}" },
              { "key": "apiType", "value": "aeps" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"{{aepsTransType}}\",\n  \"merchantId\": \"{{merchantId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/aeps/loginStatus",
            "description": "Saves **`wadh`** and **`route`** into collection vars on success. `loginStatus: false` + empty `bankList` until agent biometric login succeeds. `kycStatus: PENDING` here is AEPS pipeline state, not merchant KYC."
          },
          "response": []
        },
        {
          "name": "3.2 AEPS Login (biometric)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!(pm.collectionVariables.get('aepsWadh') || '').trim()) {",
                  "  console.warn('aepsWadh is empty — send **3.1 Check AEPS Login Status** first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response time OK', function () { pm.expect(pm.response.responseTime).to.be.below(30000); });",
                  "try {",
                  "  const j = pm.response.json();",
