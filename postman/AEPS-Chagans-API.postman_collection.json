      "description": "Raw JWT/string only (no 'Bearer '). Expired or wrong-scope token → AUTH_401."
    },
    { "key": "merchantId", "value": "69ea3db26d7c0047d40ceb2f", "description": "Validated merchant; overwritten if Create Merchant returns a new id" },
