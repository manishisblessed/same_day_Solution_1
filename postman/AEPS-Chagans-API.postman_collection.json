            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"transType\": \"{{aepsTransType}}\",\n  \"wadh\": \"{{aepsWadh}}\",\n  \"bioType\": \"FINGER\",\n  \"dc\": \"device_code\",\n  \"ci\": \"certificate_identifier\",\n  \"hmac\": \"hash_value\",\n  \"dpId\": \"device_provider_id\",\n  \"mc\": \"model_code\",\n  \"pidDataType\": \"X\",\n  \"mi\": \"model_id\",\n  \"rdsId\": \"reader_id\",\n  \"sessionKey\": \"session_key\",\n  \"fCount\": \"1\",\n  \"errCode\": \"0\",\n  \"pCount\": \"0\",\n  \"fType\": \"0\",\n  \"iCount\": \"0\",\n  \"pType\": \"0\",\n  \"srno\": \"serial_number\",\n  \"pidData\": \"encrypted_biometric_data\",\n  \"qScore\": \"80\",\n  \"nmPoints\": \"20\",\n  \"rdsVer\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/aeps/aepsLogin",
            "description": "**Resident authentication failed** = real `pidData` + device fields from RD/certified scanner; placeholders always fail. Run **3.1** first for `wadh`. Confirm `aepsTransType` (deposit/withdraw) with Chagans."
          },
          "response": []
        }
      ]
    },
